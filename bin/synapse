#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Coding Agent - CLI Entry Point
 *
 * AI-powered coding assistant built with Neuron AI framework and Symfony Console.
 */

if (php_sapi_name() !== 'cli') {
    exit;
}

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../../autoload.php',
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        break;
    }
}

use NeuronCore\Synapse\Commands\SynapseCommand;
use Symfony\Component\Console\Application;

$app = new Application('Synapse', '0.1.0');
$app->addCommand(new SynapseCommand());
$app->setDefaultCommand('synapse', true);
$app->run();
